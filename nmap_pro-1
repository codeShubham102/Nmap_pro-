}

# ----------------------------------------------------------------------------
# Resolve the real (non-root) home directory when invoked via sudo, so the
# shell alias lands in the actual user's rc files rather than root's.
# ----------------------------------------------------------------------------
get_real_home() {
    if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
        getent passwd "${SUDO_USER}" 2>/dev/null | cut -d: -f6
    else
        echo "${HOME}"
    fi
}

# ----------------------------------------------------------------------------
# Self auto-deployment
# ----------------------------------------------------------------------------
auto_deploy() {
    local current_path
    current_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "$0")"

    if [[ "${current_path}" == "${INSTALL_PATH}" ]]; then
        return
    fi

    echo -e "${YELLOW}[*] First-time execution detected: Auto-deploying script...${NC}"

    if cp -f "${current_path}" "${INSTALL_PATH}" 2>/dev/null; then
        chmod +x "${INSTALL_PATH}"
        echo -e "${GREEN}[+] Installed nmap_pro to ${INSTALL_PATH}${NC}"
    else
        echo -e "${RED}[!] Failed to copy script to ${INSTALL_PATH}. Continuing without deployment.${NC}"
        return
    fi

    local real_home
    real_home="$(get_real_home)"
    local alias_line='alias scan="sudo nmap_pro"'

    for rc_name in ".bashrc" ".zshrc"; do
        local rc_path="${real_home}/${rc_name}"
        if [[ -f "${rc_path}" ]]; then
            if ! grep -Fxq "${alias_line}" "${rc_path}" 2>/dev/null; then
                echo "${alias_line}" >> "${rc_path}"
                echo -e "${GREEN}[+] Alias added to ${rc_path}${NC}"
            else
                echo -e "${CYAN}[i] Alias already present in ${rc_path}${NC}"
            fi
        else
            echo "${alias_line}" >> "${rc_path}"
            echo -e "${GREEN}[+] Created ${rc_path} and added alias${NC}"
        fi
    done

    echo -e "${CYAN}[i] Please restart your terminal (or run 'source ~/.bashrc' / 'source ~/.zshrc')${NC}"
    echo -e "${CYAN}    to start using the 'scan' shortcut.${NC}"
    echo ""
}

# ----------------------------------------------------------------------------
# Dependency installer
# ----------------------------------------------------------------------------
check_dependencies() {
    echo -e "${CYAN}[*] Checking required dependencies...${NC}"
    detect_package_manager

    local missing=()
    for tool in "${REQUIRED_TOOLS[@]}"; do
        if ! command -v "${tool}" >/dev/null 2>&1; then
            missing+=("${tool}")
        fi
    done

    if [[ ${#missing[@]} -eq 0 ]]; then
        echo -e "${GREEN}[\xE2\x9C\x94] All required tools are installed.${NC}"
        echo ""
        return
    fi

    for tool in "${missing[@]}"; do
        echo -e "${YELLOW}[!] ${tool} is not installed.${NC}"
    done

    if [[ -z "${PKG_MANAGER}" ]]; then
        echo -e "${RED}[!] No supported package manager (apt/dnf/yum/pacman/zypper) found on this system.${NC}"
        echo -e "${RED}[!] Please install the missing tools manually: ${missing[*]}${NC}"
        echo ""
        return
    fi

    echo -e "${CYAN}[*] Detected package manager: ${PKG_MANAGER}${NC}"
    echo -e "${CYAN}[*] Updating package lists (${PKG_UPDATE_CMD})...${NC}"
    ${PKG_UPDATE_CMD} || true

    for tool in "${missing[@]}"; do
        echo -e "${YELLOW}[*] Installing ${tool}...${NC}"
        ${PKG_INSTALL_CMD} "${tool}"
        if command -v "${tool}" >/dev/null 2>&1; then
            echo -e "${GREEN}[\xE2\x9C\x94] ${tool} installed successfully.${NC}"
        else
            echo -e "${RED}[\xE2\x9C\x98] Failed to install ${tool} automatically. Please install it manually (package name may differ on your distro).${NC}"
        fi
    done
    echo ""
}

# ----------------------------------------------------------------------------
# Wordlist bootstrap: auto-installs seclists/dirb if no wordlist is present,
# instead of silently skipping the Gobuster phase.
# ----------------------------------------------------------------------------
ensure_wordlist() {
    for wl in "${GOBUSTER_WORDLIST_CANDIDATES[@]}"; do
        if [[ -f "${wl}" ]]; then
            echo "${wl}"
            return 0
        fi
    done

    echo -e "${YELLOW}[!] No Gobuster wordlist found. Attempting to install one...${NC}" >&2

    if [[ -z "${PKG_MANAGER}" ]]; then
        echo -e "${RED}[!] No package manager available to install a wordlist automatically.${NC}" >&2
        return 1
    fi

    for pkg in seclists dirb dirbuster; do
        echo -e "${CYAN}[*] Trying to install '${pkg}'...${NC}" >&2
        ${PKG_INSTALL_CMD} "${pkg}" >/dev/null 2>&1
        for wl in "${GOBUSTER_WORDLIST_CANDIDATES[@]}"; do
            if [[ -f "${wl}" ]]; then
                echo -e "${GREEN}[\xE2\x9C\x94] Wordlist now available: ${wl}${NC}" >&2
                echo "${wl}"
                return 0
            fi
        done
    done

    echo -e "${RED}[\xE2\x9C\x98] Could not obtain a wordlist automatically.${NC}" >&2
    return 1
}

# ----------------------------------------------------------------------------
# Interactive recon workflow
# ----------------------------------------------------------------------------
run_recon() {
    read -rp "$(echo -e "${CYAN}${BOLD}Enter target IP or Domain: ${NC}")" TARGET

    if [[ -z "${TARGET}" ]]; then
        echo -e "${RED}[!] No target provided. Exiting.${NC}"
        exit 1
    fi

    mkdir -p "${RESULTS_DIR}"
    local timestamp
    timestamp="$(date +%Y%m%d_%H%M%S)"
    local target_dir="${RESULTS_DIR}/${TARGET}_${timestamp}"
    mkdir -p "${target_dir}"

    local nmap_file="${target_dir}/nmap.txt"
    local web_file="${target_dir}/web_recon.txt"
    local dir_file="${target_dir}/directories.txt"
    local ssl_file="${target_dir}/ssl_report.txt"

    # -- Phase 1: Nmap --------------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 1/4] Nmap Service & Script Scan${NC}"
    nmap -sC -sV -T4 -Pn "${TARGET}" 2>&1 | tee "${nmap_file}"
    [[ -s "${nmap_file}" ]] || echo -e "${RED}[!] nmap produced no output — check target reachability / nmap install.${NC}"

    # -- Phase 2: Web recon -----------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 2/4] Web Recon (WhatWeb + Nikto)${NC}"
    {
        echo "==================== WhatWeb Results ===================="
        whatweb -a 3 "${TARGET}" 2>&1
        echo ""
        echo "===================== Nikto Results ======================"
        nikto -h "${TARGET}" 2>&1
    } | tee "${web_file}"
    [[ -s "${web_file}" ]] || echo -e "${RED}[!] whatweb/nikto produced no output — check tool install / target.${NC}"

    # -- Phase 3: Gobuster --------------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 3/4] Directory Brute Force (Gobuster)${NC}"
    local wordlist
    wordlist="$(ensure_wordlist)"
    if [[ -z "${wordlist}" ]]; then
        echo -e "${RED}[!] Skipping Gobuster — no wordlist available.${NC}"
        echo "No wordlist available (auto-install failed and none found locally)." > "${dir_file}"
    else
        gobuster dir -u "http://${TARGET}" -w "${wordlist}" -q 2>&1 | tee "${dir_file}"
        [[ -s "${dir_file}" ]] || echo -e "${RED}[!] gobuster produced no output — check target/HTTP reachability.${NC}"
    fi

    # -- Phase 4: SSLScan ----------------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 4/4] SSL/TLS Analysis (SSLScan)${NC}"
    sslscan "${TARGET}" 2>&1 | tee "${ssl_file}"
    [[ -s "${ssl_file}" ]] || echo -e "${RED}[!] sslscan produced no output — target may not serve TLS.${NC}"

    # -- Combined Final Report (printed to console) -------------------------------
    echo -e "${GREEN}${BOLD}"
    echo "================================================================"
    echo "                    NMAP_PRO FINAL REPORT"
    echo "                  Target: ${TARGET}"
    echo "================================================================"
    echo -e "${NC}"

    echo -e "${CYAN}${BOLD}>>> PHASE 1: NMAP SERVICE/SCRIPT SCAN${NC}"
    cat "${nmap_file}" 2>/dev/null
    echo ""

    echo -e "${CYAN}${BOLD}>>> PHASE 2: WEB RECON (WHATWEB + NIKTO)${NC}"
    cat "${web_file}" 2>/dev/null
    echo ""

    echo -e "${CYAN}${BOLD}>>> PHASE 3: DIRECTORY BRUTE FORCE (GOBUSTER)${NC}"
    cat "${dir_file}" 2>/dev/null
    echo ""

    echo -e "${CYAN}${BOLD}>>> PHASE 4: SSL/TLS ANALYSIS (SSLSCAN)${NC}"
    cat "${ssl_file}" 2>/dev/null
    echo ""

    echo -e "${GREEN}${BOLD}================================================================${NC}"
    echo -e "${GREEN}${BOLD}[\xE2\x9C\x94] Recon completed for target: ${TARGET}${NC}"
    echo -e "${GREEN}${BOLD}================================================================${NC}"
    echo -e "${CYAN}Full logs also saved in: $(pwd)/${target_dir}${NC}"
    echo ""
}

# ----------------------------------------------------------------------------
# Main
# ----------------------------------------------------------------------------
main() {
    print_banner

    check_root "$@"

    for arg in "$@"; do
        if [[ "${arg}" == "help-scan" ]]; then
            show_help
        fi
    done

    auto_deploy
    check_dependencies
    run_recon
}

main "$@"
