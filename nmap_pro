#!/usr/bin/env bash
#
# nmap_pro - Advanced Recon Suite
# Author: legend_hackeryt
#
# Automated reconnaissance wrapper around nmap, whatweb, nikto, gobuster
# and sslscan, with self-deployment and dependency bootstrapping.

set -uo pipefail

# ----------------------------------------------------------------------------
# Colors
# ----------------------------------------------------------------------------
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
BRIGHT_GREEN=$'\033[1;92m'
YELLOW=$'\033[1;33m'
CYAN=$'\033[1;36m'
MAGENTA=$'\033[1;35m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# ----------------------------------------------------------------------------
# Constants
# ----------------------------------------------------------------------------
SCRIPT_NAME="nmap_pro"
INSTALL_PATH="/usr/local/bin/${SCRIPT_NAME}"
RESULTS_DIR="nmap_pro_results"
REQUIRED_TOOLS=(nmap whatweb nikto gobuster sslscan)
GOBUSTER_WORDLIST_CANDIDATES=(
    "/usr/share/wordlists/dirb/common.txt"
    "/usr/share/wordlists/dirbuster/directory-list-2.3-medium.txt"
    "/usr/share/seclists/Discovery/Web-Content/common.txt"
    "/usr/share/wordlists/dirb/big.txt"
)

# ----------------------------------------------------------------------------
# Banner
# ----------------------------------------------------------------------------
print_banner() {
    clear
    echo -e "${BRIGHT_GREEN}"
    cat << "BANNER"
  _                             _   _               _              _
 | |                           | | | |             | |            | |
 | | ___  __ _  ___ _ __     __| | | |__   __ _  ___| | _____ _ __ | |_
 | |/ _ \/ _` |/ _ \ '_ \   / _` | | '_ \ / _` |/ __| |/ / _ \ '__|| __|
 | |  __/ (_| |  __/ | | | | (_| | | | | | (_| | (__|   <  __/ |   | |_
 |_|\___|\__, |\___|_| |_|  \__,_| |_| |_|\__,_|\___|_|\_\___|_|    \__|
          __/ |
         |___/
BANNER
    echo -e "${NC}"
    echo -e "${BRIGHT_GREEN}${BOLD}                         legend_hackeryt${NC}"
    echo -e "${CYAN}              [ Advanced Recon Suite - nmap_pro ]${NC}"
    echo -e "${CYAN}--------------------------------------------------------------${NC}"
    echo ""
}

# ----------------------------------------------------------------------------
# Root / sudo enforcement
# ----------------------------------------------------------------------------
check_root() {
    if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
        echo -e "${RED}${BOLD}[!] WARNING:${NC}${RED} nmap_pro must be run as root or with sudo privileges.${NC}"
        echo -e "${RED}[!] Please re-run this tool using: sudo ${SCRIPT_NAME} $*${NC}"
        exit 1
    fi
}

# ----------------------------------------------------------------------------
# Help menu
# ----------------------------------------------------------------------------
show_help() {
    cat << EOF
${BOLD}NAME${NC}
    nmap_pro - Advanced Recon Suite by legend_hackeryt

${BOLD}USAGE${NC}
    sudo nmap_pro
    sudo nmap_pro help-scan
    scan                 (after auto-deployment, via shell alias)

${BOLD}DESCRIPTION${NC}
    nmap_pro is an automated reconnaissance wrapper that chains together
    several industry-standard tools into a single guided workflow. On
    first run it deploys itself system-wide, installs any missing
    dependencies, then walks you through a 4-phase scan against a
    target IP or domain that you provide.

${BOLD}SCAN PHASES${NC}
    Phase 1  Nmap Service/Script Scan
             -sC -sV service + default script detection
             -> nmap.txt

    Phase 2  Web Recon (WhatWeb + Nikto)
             Fingerprinting and web vulnerability checks
             -> web_recon.txt

    Phase 3  Directory Brute Force (Gobuster)
             Uses standard Kali wordlists (dirb/dirbuster/seclists)
             -> directories.txt

    Phase 4  SSL/TLS Analysis (SSLScan)
             Cipher suite and certificate inspection
             -> ssl_report.txt

${BOLD}OUTPUT${NC}
    All logs are written under:
        ./${RESULTS_DIR}/<target>_<timestamp>/

${BOLD}FIRST-RUN BEHAVIOR${NC}
    - Script is copied to ${INSTALL_PATH}
    - A 'scan' alias (alias scan="sudo nmap_pro") is appended to
      ~/.bashrc and ~/.zshrc if not already present
    - Missing dependencies (nmap, whatweb, nikto, gobuster, sslscan)
      are installed automatically via apt

${BOLD}FLAGS${NC}
    help-scan     Show this help menu and exit without scanning

EOF
    exit 0
}

# ----------------------------------------------------------------------------
# Resolve the real (non-root) home directory when invoked via sudo, so the
# shell alias lands in the actual user's rc files rather than root's.
# ----------------------------------------------------------------------------
get_real_home() {
    if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
        getent passwd "${SUDO_USER}" 2>/dev/null | cut -d: -f6
    else
        echo "${HOME}"
    fi
}

# ----------------------------------------------------------------------------
# Self auto-deployment
# ----------------------------------------------------------------------------
auto_deploy() {
    local current_path
    current_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "$0")"

    if [[ "${current_path}" == "${INSTALL_PATH}" ]]; then
        return
    fi

    echo -e "${YELLOW}[*] First-time execution detected: Auto-deploying script...${NC}"

    if cp -f "${current_path}" "${INSTALL_PATH}" 2>/dev/null; then
        chmod +x "${INSTALL_PATH}"
        echo -e "${GREEN}[+] Installed nmap_pro to ${INSTALL_PATH}${NC}"
    else
        echo -e "${RED}[!] Failed to copy script to ${INSTALL_PATH}. Continuing without deployment.${NC}"
        return
    fi

    local real_home
    real_home="$(get_real_home)"
    local alias_line='alias scan="sudo nmap_pro"'

    for rc_name in ".bashrc" ".zshrc"; do
        local rc_path="${real_home}/${rc_name}"
        if [[ -f "${rc_path}" ]]; then
            if ! grep -Fxq "${alias_line}" "${rc_path}" 2>/dev/null; then
                echo "${alias_line}" >> "${rc_path}"
                echo -e "${GREEN}[+] Alias added to ${rc_path}${NC}"
            else
                echo -e "${CYAN}[i] Alias already present in ${rc_path}${NC}"
            fi
        else
            echo "${alias_line}" >> "${rc_path}"
            echo -e "${GREEN}[+] Created ${rc_path} and added alias${NC}"
        fi
    done

    echo -e "${CYAN}[i] Please restart your terminal (or run 'source ~/.bashrc' / 'source ~/.zshrc')${NC}"
    echo -e "${CYAN}    to start using the 'scan' shortcut.${NC}"
    echo ""
}

# ----------------------------------------------------------------------------
# Dependency installer
# ----------------------------------------------------------------------------
check_dependencies() {
    echo -e "${CYAN}[*] Checking required dependencies...${NC}"
    local missing=()

    for tool in "${REQUIRED_TOOLS[@]}"; do
        if ! command -v "${tool}" >/dev/null 2>&1; then
            missing+=("${tool}")
        fi
    done

    if [[ ${#missing[@]} -eq 0 ]]; then
        echo -e "${GREEN}[\xE2\x9C\x94] All required tools are installed.${NC}"
        echo ""
        return
    fi

    for tool in "${missing[@]}"; do
        echo -e "${YELLOW}[!] ${tool} is not installed.${NC}"
    done

    echo -e "${CYAN}[*] Running apt update...${NC}"
    apt update -y

    for tool in "${missing[@]}"; do
        echo -e "${YELLOW}[*] Installing ${tool}...${NC}"
        apt install -y "${tool}"
        if command -v "${tool}" >/dev/null 2>&1; then
            echo -e "${GREEN}[\xE2\x9C\x94] ${tool} installed successfully.${NC}"
        else
            echo -e "${RED}[\xE2\x9C\x98] Failed to install ${tool}. Please install it manually.${NC}"
        fi
    done
    echo ""
}

# ----------------------------------------------------------------------------
# Interactive recon workflow
# ----------------------------------------------------------------------------
run_recon() {
    read -rp "$(echo -e "${CYAN}${BOLD}Enter target IP or Domain: ${NC}")" TARGET

    if [[ -z "${TARGET}" ]]; then
        echo -e "${RED}[!] No target provided. Exiting.${NC}"
        exit 1
    fi

    mkdir -p "${RESULTS_DIR}"
    local timestamp
    timestamp="$(date +%Y%m%d_%H%M%S)"
    local target_dir="${RESULTS_DIR}/${TARGET}_${timestamp}"
    mkdir -p "${target_dir}"

    # -- Phase 1: Nmap ---------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 1/4] Nmap Service & Script Scan${NC}"
    nmap -sC -sV -T4 -Pn -oN "${target_dir}/nmap.txt" "${TARGET}"

    # -- Phase 2: Web recon ------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 2/4] Web Recon (WhatWeb + Nikto)${NC}"
    {
        echo "==================== WhatWeb Results ===================="
        whatweb -a 3 "${TARGET}"
        echo ""
        echo "===================== Nikto Results ======================"
        nikto -h "${TARGET}"
    } > "${target_dir}/web_recon.txt" 2>&1

    # -- Phase 3: Gobuster --------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 3/4] Directory Brute Force (Gobuster)${NC}"
    local wordlist=""
    for wl in "${GOBUSTER_WORDLIST_CANDIDATES[@]}"; do
        if [[ -f "${wl}" ]]; then
            wordlist="${wl}"
            break
        fi
    done

    if [[ -z "${wordlist}" ]]; then
        echo -e "${YELLOW}[!] No standard wordlist found on this system. Skipping Gobuster phase.${NC}"
        echo "No wordlist found (checked dirb/dirbuster/seclists paths)." > "${target_dir}/directories.txt"
    else
        gobuster dir -u "http://${TARGET}" -w "${wordlist}" -o "${target_dir}/directories.txt" -q
    fi

    # -- Phase 4: SSLScan ----------------------------------------------------
    echo -e "${MAGENTA}${BOLD}\n[Phase 4/4] SSL/TLS Analysis (SSLScan)${NC}"
    sslscan "${TARGET}" > "${target_dir}/ssl_report.txt" 2>&1

    # -- Summary --------------------------------------------------------------
    echo -e "${GREEN}${BOLD}\n================================================================${NC}"
    echo -e "${GREEN}${BOLD}[\xE2\x9C\x94] Recon completed successfully for target: ${TARGET}${NC}"
    echo -e "${GREEN}${BOLD}================================================================${NC}"
    echo -e "${CYAN}Logs stored in: $(pwd)/${target_dir}${NC}"
    echo -e "  - Nmap Scan   : ${target_dir}/nmap.txt"
    echo -e "  - Web Recon   : ${target_dir}/web_recon.txt"
    echo -e "  - Directories : ${target_dir}/directories.txt"
    echo -e "  - SSL Report  : ${target_dir}/ssl_report.txt"
    echo ""
}

# ----------------------------------------------------------------------------
# Main
# ----------------------------------------------------------------------------
main() {
    print_banner

    check_root "$@"

    for arg in "$@"; do
        if [[ "${arg}" == "help-scan" ]]; then
            show_help
        fi
    done

    auto_deploy
    check_dependencies
    run_recon
}

main "$@"
